    emit_adapter_result(adapter_result, output_file)


def extract_text(value):
    texts = []
    if isinstance(value, str):
        return [value]
    if isinstance(value, list):
        for item in value:
            texts.extend(extract_text(item))
    elif isinstance(value, dict):
        if isinstance(value.get("final_text"), str):
            texts.append(value["final_text"])
        for key in ("text", "content", "message", "delta", "result", "response", "output", "last_message"):
            if key in value:
                texts.extend(extract_text(value[key]))
    return texts


def read_last_message(path):
    try:
        text = path.read_text().strip()
    except Exception:
        return ""
    if not text:
        return ""
    try:
        parsed = json.loads(text)
        if isinstance(parsed, dict) and isinstance(parsed.get("final_text"), str):
            return parsed["final_text"].strip()
        texts = [t.strip() for t in extract_text(parsed) if t and t.strip()]
        if texts:
            return texts[-1]
    except Exception:
        pass
    return text


def collect_usage(event, usage):
    def add(target, value):
        try:
            usage[target] += int(value or 0)
        except Exception:
            pass

    def visit(node):
        if isinstance(node, dict):
            tokens = node.get("tokens")
            if isinstance(tokens, dict):
                add("input", tokens.get("input"))
                add("output", tokens.get("output"))
                add("total", tokens.get("total"))
            for usage_key in ("usage", "token_usage", "usage_tokens"):
                u = node.get(usage_key)
                if isinstance(u, dict):
                    add("input", u.get("input") or u.get("input_tokens") or u.get("prompt_tokens"))
                    add("output", u.get("output") or u.get("output_tokens") or u.get("completion_tokens"))
                    add("total", u.get("total") or u.get("total_tokens"))
            for key, target in (
                ("input_tokens", "input"),
                ("prompt_tokens", "input"),
                ("cached_input_tokens", "input"),
                ("cache_read_input_tokens", "input"),
                ("output_tokens", "output"),
                ("completion_tokens", "output"),
                ("total_tokens", "total"),
            ):
                if key in node:
                    add(target, node.get(key))
            for child_node in node.values():
                visit(child_node)
        elif isinstance(node, list):
            for child_node in node:
                visit(child_node)
    visit(event)


def collect_tool_calls(event, tool_calls):
    if not isinstance(event, dict):
        return
    packed = json.dumps(event, ensure_ascii=False).lower()
    if not any(marker in packed for marker in ("tool", "command", "bash", "exec", "patch", "edit", "read")):
        return
    name = event.get("tool") or event.get("toolName") or event.get("tool_name") or event.get("name")
    if not name and event.get("type") in {"tool", "tool_call", "tool_use", "command", "exec_command"}:
        name = event.get("type")
    msg = event.get("msg")
    if not name and isinstance(msg, dict):
        name = msg.get("tool") or msg.get("tool_name") or msg.get("name")
        if not name and msg.get("type") in {"tool", "tool_call", "tool_use", "command", "exec_command"}:
            name = msg.get("type")
    if not name:
        return
    source = msg if isinstance(msg, dict) else event
    args = source.get("args") or source.get("input") or source.get("command") or source.get("parameters") or source.get("cmd") or ""
    outcome = "err" if source.get("error") or source.get("is_error") or source.get("exit_code") not in (None, 0) else "ok"
    tool_calls.append({"tool": str(name), "args_summary": truncate(json.dumps(args, ensure_ascii=False) if isinstance(args, (dict, list)) else args), "outcome": outcome})


def discover_session_id(event):
    found = None

    def visit(node, parent_key=""):
        nonlocal found
        if found:
            return
        if isinstance(node, dict):
            for key, value in node.items():
                lowered = key.lower()
                if isinstance(value, str) and ("session" in lowered or lowered in {"conversation_id", "thread_id"}):
                    found = value
                    return
                visit(value, lowered)
        elif isinstance(node, list):
            for item in node:
                visit(item, parent_key)
    visit(event)
    return found


def parse_runtime(stdout_lines, last_message_path):
    final_text = read_last_message(last_message_path)
    usage = {"input": 0, "output": 0, "total": 0}
    tool_calls = []
    runtime_session_id = None
    for line in stdout_lines:
        try:
            event = json.loads(line)
        except Exception:
            if line.strip() and not final_text:
                final_text = line.strip()
            continue
        if isinstance(event, dict):
            runtime_session_id = discover_session_id(event) or runtime_session_id
            collect_usage(event, usage)
            collect_tool_calls(event, tool_calls)
            texts = [t.strip() for t in extract_text(event) if t and t.strip()]
            if texts and not final_text:
                final_text = texts[-1]
    usage_tokens = None
    total = usage["total"] or usage["input"] + usage["output"]
    if total > 0:
        usage_tokens = {"input": usage["input"], "output": usage["output"], "total": total}
    return final_text, (tool_calls or None), usage_tokens, runtime_session_id


def send_signal_to_child(sig):
    global child, child_pgid
    if child and child.poll() is None:
        try:
            if child_pgid:
                os.killpg(child_pgid, sig)
            else:
                child.send_signal(sig)
        except Exception:
            pass


def signal_handler(signum, frame):
    global interrupt_at
    if signum == signal.SIGTERM:
        interrupt_at = interrupt_at or time.time()
        send_signal_to_child(signal.SIGTERM)
        return
    if interrupt_at and time.time() - interrupt_at <= 3:
        send_signal_to_child(signal.SIGKILL)
        return
    interrupt_at = time.time()
    send_signal_to_child(signal.SIGINT)


def child_env(paths):
    env = {"PATH": os.environ.get("PATH", ""), "CODEX_HOME": str(paths["codex_home"])}
    for key in OPENAI_ENV_ALLOWLIST:
        if os.environ.get(key):
            env[key] = os.environ[key]
    return env


def provision_isolated_auth(codex, paths):
    if not os.environ.get("OPENAI_API_KEY"):
        return True, ""
    try:
        completed = subprocess.run(
            [codex, "login", "--with-api-key"],
            input=os.environ["OPENAI_API_KEY"] + "\n",
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=child_env(paths),
            timeout=30,
        )
    except Exception as exc:
        return False, f"codex isolated auth provision failed: {exc}"
    if completed.returncode != 0:
        detail = (completed.stderr or completed.stdout or "codex login failed").strip()
        return False, f"codex isolated auth provision failed: {detail}"
    return True, ""


def cleanup_isolated_auth(paths):
    for rel in ("auth.json", "auth.toml"):
        try:
            (paths["codex_home"] / rel).unlink()
        except FileNotFoundError:
            pass
        except Exception:
            pass


def sandbox_for(req):
    override = os.environ.get("AIPLUS_CODEX_SANDBOX")
    if override in {"read-only", "workspace-write", "danger-full-access"}:
        return override
    write_or_exec = {"bash", "shell", "edit", "write", "multiedit", "apply_patch", "exec"}
    requested = {str(tool).lower() for tool in req.get("allowed_tools", [])}
    if requested & write_or_exec:
        return "workspace-write"
    return "read-only"


def codex_bin():
    override = os.environ.get("AIPLUS_CODEX_BIN")
    if override:
        return override if Path(override).exists() else None
    return shutil.which("codex")


def run_codex(req, paths, isolation_sentinel, mapping_path, mapping):
    global child, child_pgid, term_sent
    codex = codex_bin()
    if not codex:
        return None, result(req["session_id"], "", None, "RUNTIME_NOT_FOUND", True)
    auth_ok, auth_reason = provision_isolated_auth(codex, paths)
    if not auth_ok:
        return None, result(req["session_id"], auth_reason, auth_reason, "RUNTIME_FAILURE", True)

    try:
        paths["last_message"].unlink()
    except FileNotFoundError:
        pass
    except Exception:
        pass

    session_entry = mapping["entries"].get(req["session_id"])
    resume_id = session_entry.get("runtime_session_id") if session_entry and req.get("continuation_hint") == "continue" else None
    common_flags = [
        "--json",
        "--ignore-user-config",
        "--ignore-rules",
        "--output-last-message",
        str(paths["last_message"]),
        "-c",
        'aiplus_adapter.marker="codex"',
        "-c",
        f'aiplus_adapter.sentinel={json.dumps(isolation_sentinel)}',
        "-c",
        'web_search="disabled"',
    ]
    model = os.environ.get("AIPLUS_CODEX_MODEL")
    if model:
        common_flags.extend(["--model", model])
    prompt = compose_prompt(req, isolation_sentinel)
    if resume_id:
        cmd = [codex, "exec", "resume", *common_flags, resume_id, "-"]
    else:
        cmd = [
            codex,
            "exec",
            *common_flags,
            "-C",
            req["worktree_path"],
            "--sandbox",
            sandbox_for(req),
            "--output-schema",
            str(paths["schema"]),
            "-",
        ]

    stdout_lines = []
    stderr_lines = []
    child = subprocess.Popen(
        cmd,
        cwd=req["worktree_path"],
        env=child_env(paths),
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        bufsize=1,
        preexec_fn=os.setsid,
    )
    try:
        child_pgid = os.getpgid(child.pid)
    except Exception:
        child_pgid = None
    try:
        child.stdin.write(prompt)
        child.stdin.close()
    except Exception:
        pass

    deadline = time.time() + max(1, int(req.get("ttl_seconds", 1800)))
    if child.stdout:
        os.set_blocking(child.stdout.fileno(), False)
    if child.stderr:
        os.set_blocking(child.stderr.fileno(), False)
    stdout_buffer = ""
    stderr_buffer = ""
    while True:
        read_fds = [fd for fd in (child.stdout, child.stderr) if fd]
        if read_fds:
            readable, _, _ = select.select(read_fds, [], [], 0.1)
            for stream in readable:
                try:
                    chunk = stream.read()
                except Exception:
                    chunk = ""
                if not chunk:
                    continue
                if stream is child.stdout:
                    stdout_buffer += chunk
                    while "\n" in stdout_buffer:
                        line, stdout_buffer = stdout_buffer.split("\n", 1)
                        stdout_lines.append(line)
                        print(line + "\n", end="", flush=True)
                else:
                    stderr_buffer += chunk
                    while "\n" in stderr_buffer:
                        line, stderr_buffer = stderr_buffer.split("\n", 1)
                        stderr_lines.append(line)
        if child.poll() is not None:
            if stdout_buffer:
                stdout_lines.append(stdout_buffer.rstrip("\n"))
                print(stdout_buffer, end="", flush=True)
            if stderr_buffer:
                stderr_lines.append(stderr_buffer.rstrip("\n"))
            break
        now = time.time()
        if interrupt_at:
            if not term_sent and now - interrupt_at >= 5:
                send_signal_to_child(signal.SIGTERM)
                term_sent = True
            if now - interrupt_at >= 10:
                send_signal_to_child(signal.SIGKILL)
        if now >= deadline:
            send_signal_to_child(signal.SIGTERM)
            time.sleep(1)
            send_signal_to_child(signal.SIGKILL)
            break
        time.sleep(0.05)

    cleanup_isolated_auth(paths)
    final_text, tool_calls, usage_tokens, runtime_session_id = parse_runtime(stdout_lines, paths["last_message"])
    stdout_raw = "\n".join(stdout_lines)
    if stderr_lines:
        stdout_raw = stdout_raw + ("\n" if stdout_raw else "") + "\n".join(stderr_lines)
    if interrupt_at:
        adapter_result = result(req["session_id"], stdout_raw, final_text, "OWNER_INTERRUPTED", True, tool_calls, usage_tokens)
    elif child.returncode == 0:
        adapter_result = result(req["session_id"], stdout_raw, final_text, "OK", False, tool_calls, usage_tokens)
    else:
        adapter_result = result(req["session_id"], stdout_raw, final_text, "RUNTIME_FAILURE", True, tool_calls, usage_tokens)

    if adapter_result["exit_status"] == "OK":
        now_iso = utc_now()
        runtime_id = runtime_session_id or req["session_id"]
        prior = mapping["entries"].get(req["session_id"], {})
        mapping["entries"][req["session_id"]] = {
            "runtime_session_id": runtime_id,
            "created_at": prior.get("created_at", now_iso),
            "last_used_at": now_iso,
            "role": req["role"],
        }
        save_mapping(mapping_path, mapping)
    return child.returncode, adapter_result


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--output-file")
    parser.add_argument("--request-file")
    args = parser.parse_args()
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    req = {}
    try:
        req = load_request(args)
        validate_request(req)
    except Exception as exc:
        session_id = req.get("session_id", "") if isinstance(req, dict) else ""
        adapter_result = result(session_id, "", str(exc), "ADAPTER_REQUEST_INVALID", True)
        emit_adapter_result(adapter_result, args.output_file)
        return EX_TEMPFAIL

    append_trace(req["worktree_path"], req["session_id"], "AdapterRequest", req)

    ok, reason = verify_worktree(req)
    if not ok:
        adapter_result = result(req["session_id"], "", reason, "WORKSPACE_NOT_PROVISIONED", True)
        append_trace(req["worktree_path"], req["session_id"], "AdapterResult", adapter_result)
        emit_adapter_result(adapter_result, args.output_file)
        return 1

    try:
        paths, isolation_sentinel = prepare_isolation(req["worktree_path"])
    except Exception as exc:
        adapter_result = result(req["session_id"], "", str(exc), "ISOLATION_BREACH", True)
        append_trace(req["worktree_path"], req["session_id"], "AdapterResult", adapter_result)
        emit_adapter_result(adapter_result, args.output_file)
        return 1

    mapping_path, mapping, corrupted = load_mapping(req["worktree_path"])
    if corrupted:
        append_trace(req["worktree_path"], req["session_id"], "session_mapping_corruption_recovered", {"path": str(mapping_path)})

    _returncode, adapter_result = run_codex(req, paths, isolation_sentinel, mapping_path, mapping)
    append_trace(req["worktree_path"], req["session_id"], "AdapterResult", adapter_result)
    if adapter_result["exit_status"] == "RUNTIME_NOT_FOUND":
        fallback_print(req, adapter_result, args.output_file)
        return EX_TEMPFAIL
    emit_adapter_result(adapter_result, args.output_file)
    return 0 if adapter_result["exit_status"] == "OK" else 1


if __name__ == "__main__":
    sys.exit(main())
